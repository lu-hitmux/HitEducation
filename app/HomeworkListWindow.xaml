<Window x:Class="HitEducation.App.HomeworkListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="作业列表"
        Icon="icons/hiteducation-app-mono.ico"
        Width="640"
        MinWidth="640"
        Height="720"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        Closing="Window_Closing">
    <Border x:Name="ListRoot"
            Padding="18"
            CornerRadius="24"
            Background="#F2FFFFFF"
            TextElement.FontSize="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  Margin="-18,-18,-18,12"
                  Background="Transparent"
                  MouseLeftButtonDown="DragBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.ColumnSpan="2" Background="#D9FFFFFF" CornerRadius="24,24,0,0" IsHitTestVisible="False" />

                <StackPanel Orientation="Horizontal" Margin="18,18,18,0">
                    <Button x:Name="ActiveButton"
                            MinWidth="118"
                            Height="44"
                            Margin="0,0,8,0"
                            Click="Active_Click" />
                    <Button x:Name="HistoryButton"
                            MinWidth="118"
                            Height="44"
                            Click="History_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="26" Height="26" Margin="0,0,8,0" Source="icons/history-archive-mono.png" />
                            <TextBlock x:Name="HistoryButtonText" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="0,18,18,0"
                            Orientation="Horizontal"
                            Visibility="Collapsed">
                    <Button x:Name="BatchArchiveButton"
                            MinWidth="96"
                            Height="40"
                            Margin="8,0,0,0"
                            Click="BatchArchive_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20"
                                   Height="20"
                                   Margin="0,0,6,0"
                                   Source="icons/history-archive-mono.png" />
                            <TextBlock x:Name="BatchArchiveButtonText" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BatchRestoreButton"
                            MinWidth="96"
                            Height="40"
                            Margin="8,0,0,0"
                            Click="BatchRestore_Click" />
                    <Button x:Name="BatchDeleteButton"
                            MinWidth="96"
                            Height="40"
                            Margin="8,0,0,0"
                            Click="BatchDelete_Click" />
                </StackPanel>
            </Grid>

            <ListBox x:Name="HomeworkList"
                     Grid.Row="1"
                     Margin="0,0,0,14"
                     Background="Transparent"
                     BorderBrush="Transparent"
                     HorizontalContentAlignment="Stretch"
                     SelectionMode="Extended"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="FooterBatchArchiveButton"
                        Width="92"
                        Height="92"
                        Margin="8,0,0,0"
                        Padding="6"
                        FontSize="15"
                        Click="BatchArchive_Click">
                    <StackPanel>
                        <Image Width="30" Height="30" HorizontalAlignment="Center" Margin="0,0,0,4" Source="icons/history-archive-mono.png" />
                        <TextBlock x:Name="FooterBatchArchiveText" TextAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button x:Name="FooterBatchRestoreButton"
                        Width="92"
                        Height="92"
                        Margin="8,0,0,0"
                        Padding="6"
                        FontSize="15"
                        Click="BatchRestore_Click">
                    <StackPanel>
                        <Image Width="30" Height="30" HorizontalAlignment="Center" Margin="0,0,0,4" Source="icons/history-archive-mono.png" />
                        <TextBlock x:Name="FooterBatchRestoreText" TextAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Button>
                <Button x:Name="FooterBatchDeleteButton"
                        Width="92"
                        Height="92"
                        Margin="8,0,0,0"
                        Padding="6"
                        FontSize="15"
                        Click="BatchDelete_Click">
                    <TextBlock x:Name="FooterBatchDeleteText"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Button>
                <Button x:Name="UndoButton"
                        Width="92"
                        Height="92"
                        Margin="8,0,0,0"
                        Padding="6"
                        FontSize="15"
                        Click="UndoButton_Click">
                    <TextBlock x:Name="UndoButtonText"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Button>
                <Button x:Name="RedoButton"
                        Width="92"
                        Height="92"
                        Margin="8,0,0,0"
                        Padding="6"
                        FontSize="15"
                        Click="RedoButton_Click">
                    <TextBlock x:Name="RedoButtonText"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Button>
                <Button x:Name="CloseButton"
                        Width="92"
                        Height="92"
                        Margin="8,0,0,0"
                        Padding="6"
                        FontSize="15"
                        Click="CloseButton_Click">
                    <TextBlock x:Name="CloseButtonText"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
