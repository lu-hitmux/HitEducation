<Window x:Class="HitEducation.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="课堂作业"
        Icon="icons/hiteducation-app-mono.ico"
        Width="520"
        Height="420"
        MinWidth="320"
        MinHeight="96"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="False"
        UseLayoutRounding="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        LocationChanged="Window_StateChanged"
        SizeChanged="Window_StateChanged"
        ManipulationDelta="Window_ManipulationDelta">
    <Grid>
        <Border x:Name="RootPanel" CornerRadius="20" Background="#F2FFFFFF" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid x:Name="HeaderBar"
                      Grid.Row="0"
                      Height="68"
                      Margin="-10,-10,-10,0"
                      Background="Transparent"
                      MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown"
                      TouchDown="HeaderBar_TouchDown"
                      TouchMove="HeaderBar_TouchMove"
                      TouchUp="HeaderBar_TouchUp"
                      LostTouchCapture="HeaderBar_LostTouchCapture">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.ColumnSpan="2" Background="#D9FFFFFF" CornerRadius="20,20,0,0" IsHitTestVisible="False" />

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="22,10,8,0">
                        <Image Width="28" Height="28" Margin="0,0,8,0" Source="icons/hiteducation-app-mono.png" />
                        <StackPanel>
                            <TextBlock x:Name="TitleText" FontSize="20" LineHeight="24" LineStackingStrategy="BlockLineHeight" FontWeight="Bold" Foreground="#0F172A" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="CountText" FontSize="13" LineHeight="17" LineStackingStrategy="BlockLineHeight" Foreground="#475569" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="HeaderButtonsPanel" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,18,0">
                        <Button x:Name="AddButton"
                                MinWidth="68"
                                Height="38"
                                Margin="6,0,0,0"
                                Click="AddButton_Click"
                                PreviewTouchDown="HeaderButton_PreviewTouchDown"
                                PreviewTouchMove="HeaderButton_PreviewTouchMove"
                                PreviewTouchUp="HeaderButton_PreviewTouchUp">
                            <StackPanel Orientation="Horizontal">
                                <Image Width="24" Height="24" Margin="0,0,6,0" Source="icons/add-homework-mono.png" />
                                <TextBlock x:Name="AddButtonText" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SettingsButton"
                                MinWidth="68"
                                Height="38"
                                Margin="6,0,0,0"
                                Click="SettingsButton_Click"
                                PreviewTouchDown="HeaderButton_PreviewTouchDown"
                                PreviewTouchMove="HeaderButton_PreviewTouchMove"
                                PreviewTouchUp="HeaderButton_PreviewTouchUp" />
                        <Button x:Name="HideButton"
                                MinWidth="68"
                                Height="38"
                                Margin="6,0,0,0"
                                Click="HideButton_Click"
                                PreviewTouchDown="HeaderButton_PreviewTouchDown"
                                PreviewTouchMove="HeaderButton_PreviewTouchMove"
                                PreviewTouchUp="HeaderButton_PreviewTouchUp" />
                        <Button x:Name="MoreButton"
                                MinWidth="48"
                                Height="38"
                                Margin="6,0,0,0"
                                Click="MoreButton_Click"
                                PreviewTouchDown="HeaderButton_PreviewTouchDown"
                                PreviewTouchMove="HeaderButton_PreviewTouchMove"
                                PreviewTouchUp="HeaderButton_PreviewTouchUp" />
                    </StackPanel>
                </Grid>

                <Grid x:Name="ContentArea" Grid.Row="1" Margin="0,10,0,0">
                    <Border x:Name="ContentBackgroundImage"
                            CornerRadius="16"
                            IsHitTestVisible="False"
                            ClipToBounds="True"
                            Visibility="Collapsed" />

                    <ScrollViewer x:Name="HomeworkScroll"
                                  PanningMode="VerticalOnly"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="HomeworkScroll_PreviewMouseWheel"
                                  SizeChanged="HomeworkScroll_SizeChanged"
                                  ScrollChanged="HomeworkScroll_ScrollChanged"
                                  TouchDown="HomeworkScroll_TouchActivity">
                        <ItemsControl x:Name="HomeworkItems" Margin="0" SizeChanged="HomeworkItems_SizeChanged">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border x:Name="EmptyToolbar" Padding="14" CornerRadius="16" Background="#F2FFFFFF" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="EmptyText" VerticalAlignment="Center" FontSize="18" Margin="0,0,12,0" />
                            <Button x:Name="EmptyAddButton"
                                    MinWidth="96"
                                    Height="42"
                                    Click="AddButton_Click"
                                    PreviewTouchDown="HeaderButton_PreviewTouchDown"
                                    PreviewTouchMove="HeaderButton_PreviewTouchMove"
                                    PreviewTouchUp="HeaderButton_PreviewTouchUp">
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="26" Height="26" Margin="0,0,8,0" Source="icons/add-homework-mono.png" />
                                    <TextBlock x:Name="EmptyAddButtonText" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid x:Name="ResizeLayer" IsHitTestVisible="True">
            <Border Height="10" VerticalAlignment="Top" Background="Transparent" Cursor="SizeNS" MouseLeftButtonDown="ResizeTop_MouseLeftButtonDown" TouchDown="ResizeTop_TouchDown" TouchMove="Resize_TouchMove" TouchUp="Resize_TouchUp" LostTouchCapture="Resize_LostTouchCapture" />
            <Border Height="10" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNS" MouseLeftButtonDown="ResizeBottom_MouseLeftButtonDown" TouchDown="ResizeBottom_TouchDown" TouchMove="Resize_TouchMove" TouchUp="Resize_TouchUp" LostTouchCapture="Resize_LostTouchCapture" />
            <Border Width="10" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWE" MouseLeftButtonDown="ResizeLeft_MouseLeftButtonDown" TouchDown="ResizeLeft_TouchDown" TouchMove="Resize_TouchMove" TouchUp="Resize_TouchUp" LostTouchCapture="Resize_LostTouchCapture" />
            <Border Width="10" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWE" MouseLeftButtonDown="ResizeRight_MouseLeftButtonDown" TouchDown="ResizeRight_TouchDown" TouchMove="Resize_TouchMove" TouchUp="Resize_TouchUp" LostTouchCapture="Resize_LostTouchCapture" />
            <Border Width="18" Height="18" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent" Cursor="SizeNWSE" MouseLeftButtonDown="ResizeTopLeft_MouseLeftButtonDown" TouchDown="ResizeTopLeft_TouchDown" TouchMove="Resize_TouchMove" TouchUp="Resize_TouchUp" LostTouchCapture="Resize_LostTouchCapture" />
            <Border Width="18" Height="18" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" Cursor="SizeNESW" MouseLeftButtonDown="ResizeTopRight_MouseLeftButtonDown" TouchDown="ResizeTopRight_TouchDown" TouchMove="Resize_TouchMove" TouchUp="Resize_TouchUp" LostTouchCapture="Resize_LostTouchCapture" />
            <Border Width="18" Height="18" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNESW" MouseLeftButtonDown="ResizeBottomLeft_MouseLeftButtonDown" TouchDown="ResizeBottomLeft_TouchDown" TouchMove="Resize_TouchMove" TouchUp="Resize_TouchUp" LostTouchCapture="Resize_LostTouchCapture" />
            <Border Width="18" Height="18" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNWSE" MouseLeftButtonDown="ResizeBottomRight_MouseLeftButtonDown" TouchDown="ResizeBottomRight_TouchDown" TouchMove="Resize_TouchMove" TouchUp="Resize_TouchUp" LostTouchCapture="Resize_LostTouchCapture" />
        </Grid>
    </Grid>
</Window>
