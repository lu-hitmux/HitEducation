<Window x:Class="HitEducation.App.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="900"
        Height="86"
        Icon="icons/hiteducation-app-mono.ico"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Loaded="Window_Loaded">
    <Border x:Name="NotificationRoot" Background="#EE172033" CornerRadius="0,0,8,8" Padding="24,14" BorderBrush="#334155" BorderThickness="0,0,0,1">
        <DockPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="0,0,22,0" VerticalAlignment="Center">
                <Image Source="icons/reminder-mono.png" Width="24" Height="24" Margin="0,0,8,0" />
                <TextBlock x:Name="LabelText" Text="作业提醒" Foreground="#FBBF24" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel>
                <TextBlock x:Name="TitleText" Foreground="White" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="DetailText" Foreground="#CBD5E1" FontSize="15" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
