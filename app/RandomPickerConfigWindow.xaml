<Window x:Class="HitEducation.App.RandomPickerConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="点名配置"
        Icon="icons/hiteducation-app-mono.ico"
        Width="540"
        Height="640"
        MinWidth="480"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        UseLayoutRounding="True">
    <Border x:Name="ConfigRoot" Padding="18" CornerRadius="24" Background="#F2FFFFFF" TextElement.FontSize="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar" Grid.Row="0" Margin="-18,-18,-18,12" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border Background="#D9FFFFFF" CornerRadius="24,24,0,0" IsHitTestVisible="False" />
                <TextBlock x:Name="TitleText" Margin="22,24,22,10" FontSize="21" FontWeight="Bold" Foreground="#0F172A" Text="点名配置" />
            </Grid>

            <StackPanel Grid.Row="1" Margin="2,0,2,12">
                <TextBlock x:Name="RosterLabel" FontWeight="Bold" Margin="0,0,0,6" Text="当前名单" />
                <ComboBox x:Name="RosterBox" Height="40" DisplayMemberPath="Name" SelectionChanged="RosterBox_SelectionChanged" />
            </StackPanel>

            <TextBlock x:Name="HelpText" Grid.Row="2" Foreground="#64748B" TextWrapping="Wrap" Margin="2,0,2,12" />

            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                <ItemsControl x:Name="MemberItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="12" CornerRadius="14" Background="#EAF2FF">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="74" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="56" />
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0" Source="{Binding ThumbnailPath}" Width="64" Height="36" Stretch="UniformToFill" />
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" Margin="8,0,0,0" />
                                    <Slider Grid.Column="2" Minimum="0" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True" IsMoveToPointEnabled="True" Value="{Binding SliderValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="12,0" />
                                    <TextBlock Grid.Column="3" Text="{Binding WeightText}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button x:Name="CancelButton" MinWidth="86" Height="42" Margin="8,0,0,0" Click="Cancel_Click" Content="取消" />
                <Button x:Name="OkButton" MinWidth="86" Height="42" Margin="8,0,0,0" Click="Ok_Click" Content="确定" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
