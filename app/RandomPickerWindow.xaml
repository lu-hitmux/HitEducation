<Window x:Class="HitEducation.App.RandomPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="随机点名"
        Icon="icons/hiteducation-app-mono.ico"
        Width="620"
        Height="520"
        MinWidth="520"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        AllowDrop="True"
        PreviewDragOver="Window_DragOver"
        PreviewDrop="Window_Drop">
    <Border x:Name="PickerRoot"
            Padding="18"
            CornerRadius="24"
            Background="#F2FFFFFF"
            TextElement.FontSize="17"
            AllowDrop="True"
            PreviewDragOver="Window_DragOver"
            PreviewDrop="Window_Drop">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar" Grid.Row="0" Margin="-18,-18,-18,12" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border Background="#D9FFFFFF" CornerRadius="24,24,0,0" IsHitTestVisible="False" />
                <TextBlock x:Name="TitleText" Margin="22,24,22,10" FontSize="21" FontWeight="Bold" Foreground="#0F172A" Text="随机点名" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="StatusText" Grid.Row="0" Foreground="#64748B" TextWrapping="Wrap" Margin="2,0,2,16" />
                <Border x:Name="SamplePanel" Grid.Row="1" Visibility="Collapsed" CornerRadius="14" Background="#ECFDF5" Padding="12" Margin="0,0,0,14">
                    <TextBlock x:Name="SampleText" FontSize="14" Foreground="#166534" TextWrapping="Wrap" />
                </Border>
                <Border Grid.Row="2" CornerRadius="22" Background="#E0F2FE" Padding="18">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image x:Name="SlideImage" MaxWidth="500" MaxHeight="300" Stretch="Uniform" Visibility="Collapsed" Margin="0,0,0,14" />
                            <TextBlock x:Name="NameText"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       FontSize="52"
                                       FontWeight="Bold"
                                       Foreground="#0F172A"
                                       Text="请先导入名单" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="ImportButton" Grid.Column="0" MinWidth="108" Height="44" Margin="0,0,8,0" Click="Import_Click" Content="导入名单" />
                <Button x:Name="SampleButton" Grid.Column="1" MinWidth="108" Height="44" HorizontalAlignment="Left" Click="Sample_Click" Content="查看样例" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ConfigButton" MinWidth="92" Height="44" Margin="8,0,0,0" Click="Config_Click" Content="配置" />
                    <Button x:Name="StartButton" MinWidth="130" Height="44" Margin="8,0,0,0" Click="Start_Click" Content="开始点名" />
                    <Button x:Name="CloseButton" MinWidth="86" Height="44" Margin="8,0,0,0" Click="Close_Click" Content="关闭" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
