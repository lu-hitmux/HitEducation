<Window x:Class="HitEducation.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Icon="icons/hiteducation-app-mono.ico"
        Width="640"
        MinWidth="640"
        Height="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        UseLayoutRounding="True">
    <Border x:Name="SettingsRoot" Padding="18" CornerRadius="24" Background="#F2FFFFFF" TextElement.FontSize="17">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar" Grid.Row="0" Margin="-18,-18,-18,12" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border Background="#D9FFFFFF" CornerRadius="24,24,0,0" IsHitTestVisible="False" />
                <TextBlock x:Name="TitleText" Margin="22,24,22,10" FontSize="21" FontWeight="Bold" Foreground="#0F172A" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                <StackPanel x:Name="SettingsContent">
                    <TextBlock x:Name="LanguageLabel" FontWeight="Bold" />
                    <ComboBox x:Name="LanguageBox" Margin="0,6,0,12" Height="40" SelectionChanged="LanguageBox_SelectionChanged">
                        <ComboBoxItem Tag="zh-CN" Content="简体中文" />
                        <ComboBoxItem Tag="en" Content="English" />
                    </ComboBox>

                    <UniformGrid Columns="2" Margin="0,0,0,12">
                        <UniformGrid.Resources>
                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Left" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                            </Style>
                        </UniformGrid.Resources>
                        <CheckBox x:Name="TopmostBox" Margin="0,4,8,4" />
                        <CheckBox x:Name="AutoStartBox" Margin="8,4,0,4" />
                        <CheckBox x:Name="AutoUpdateBox" Margin="0,4,8,4" />
                        <CheckBox x:Name="LockBox" Margin="8,4,0,4" />
                        <CheckBox x:Name="FullscreenDetectionBox" Margin="0,4,8,4" />
                        <CheckBox x:Name="BackgroundImageBox" Margin="8,4,0,4" />
                    </UniformGrid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="BackgroundImagePathText" Grid.Column="0" VerticalAlignment="Center" Foreground="#64748B" TextTrimming="CharacterEllipsis" />
                        <Button x:Name="ChooseBackgroundImageButton" Grid.Column="1" MinWidth="112" Height="38" Margin="12,0,0,0" Click="ChooseBackgroundImage_Click" />
                    </Grid>

                    <TextBlock x:Name="BackgroundOpacityLabel" FontWeight="Bold" />
                    <Slider x:Name="BackgroundOpacitySlider" Minimum="0.25" Maximum="1" TickFrequency="0.05" IsMoveToPointEnabled="True" Margin="0,4,0,10" ValueChanged="LiveSlider_ValueChanged" />
                    <TextBlock x:Name="FontOpacityLabel" FontWeight="Bold" />
                    <Slider x:Name="FontOpacitySlider" Minimum="0.25" Maximum="1" TickFrequency="0.05" IsMoveToPointEnabled="True" Margin="0,4,0,10" ValueChanged="LiveSlider_ValueChanged" />
                    <TextBlock x:Name="FontSizeLabel" FontWeight="Bold" />
                    <Slider x:Name="FontSizeSlider" Minimum="14" Maximum="42" TickFrequency="1" IsMoveToPointEnabled="True" Margin="0,4,0,10" ValueChanged="LiveSlider_ValueChanged" />
                    <TextBlock x:Name="AutoScrollSpeedLabel" FontWeight="Bold" />
                    <Slider x:Name="AutoScrollSpeedSlider" Minimum="0" Maximum="8" TickFrequency="0.5" IsMoveToPointEnabled="True" Margin="0,4,0,12" ValueChanged="LiveSlider_ValueChanged" />

                    <UniformGrid Columns="2" Margin="0,0,0,12">
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock x:Name="AutoScrollIdleLabel" />
                            <TextBox x:Name="AutoScrollIdleSecondsBox" Height="36" Padding="8" />
                        </StackPanel>
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock x:Name="AutoScrollPauseLabel" />
                            <TextBox x:Name="AutoScrollPauseSecondsBox" Height="36" Padding="8" />
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock x:Name="ReminderHeader" FontSize="17" FontWeight="Bold" Margin="0,10,0,8" />
                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock x:Name="RemindMinutesLabel" />
                            <TextBox x:Name="RemindMinutesBox" Height="36" Padding="8" />
                        </StackPanel>
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock x:Name="NotificationDurationLabel" />
                            <TextBox x:Name="NotificationDurationBox" Height="36" Padding="8" />
                        </StackPanel>
                    </UniformGrid>
                    <TextBlock x:Name="UpcomingTemplateLabel" />
                    <TextBox x:Name="UpcomingReminderTemplateBox" Height="70" Margin="0,4,0,8" AcceptsReturn="True" TextWrapping="Wrap" Padding="8" />
                    <TextBlock x:Name="DueTemplateLabel" />
                    <TextBox x:Name="DueReminderTemplateBox" Height="70" Margin="0,4,0,8" AcceptsReturn="True" TextWrapping="Wrap" Padding="8" />
                    <TextBlock x:Name="PlaceholdersHelpText" TextWrapping="Wrap" Foreground="#64748B" Margin="0,0,0,12" />

                    <TextBlock x:Name="QuickTimeHeader" FontSize="17" FontWeight="Bold" Margin="0,10,0,4" />
                    <TextBlock x:Name="QuickTimeHelpText" TextWrapping="Wrap" Foreground="#64748B" />
                    <TextBox x:Name="QuickTimeRulesBox" Height="100" Margin="0,6,0,12" AcceptsReturn="True" TextWrapping="Wrap" Padding="8" />

                    <TextBlock x:Name="SubjectsHeader" FontSize="17" FontWeight="Bold" Margin="0,10,0,4" />
                    <TextBlock x:Name="TemplatesHelpText" TextWrapping="Wrap" Foreground="#64748B" />
                    <TextBox x:Name="SubjectsBox" Height="120" Margin="0,6,0,12" AcceptsReturn="True" TextWrapping="Wrap" Padding="8" />

                    <TextBlock x:Name="ClassPeriodsHeader" FontSize="17" FontWeight="Bold" Margin="0,10,0,6" />
                    <ComboBox x:Name="ClassPeriodDaysBox" Height="38" Margin="0,0,0,6">
                        <ComboBoxItem x:Name="WeekdaysOnlyItem" />
                        <ComboBoxItem x:Name="EveryDayItem" />
                    </ComboBox>
                    <TextBox x:Name="ClassPeriodsBox" Height="90" Margin="0,0,0,12" AcceptsReturn="True" TextWrapping="Wrap" Padding="8" />

                    <TextBlock x:Name="FullscreenHeader" FontSize="17" FontWeight="Bold" Margin="0,10,0,4" />
                    <TextBlock x:Name="FullscreenHelpText" TextWrapping="Wrap" Foreground="#64748B" />
                    <Grid Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="WhitelistLabel" />
                            <TextBox x:Name="FullscreenProcessBox" Height="90" Margin="0,4,0,0" AcceptsReturn="True" TextWrapping="Wrap" Padding="8" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="BlacklistLabel" />
                            <TextBox x:Name="FullscreenBlockedProcessBox" Height="90" Margin="0,4,0,0" AcceptsReturn="True" TextWrapping="Wrap" Padding="8" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,14,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                    <Button x:Name="CheckUpdateButton" MinWidth="112" Height="42" Margin="8,0,0,0" Click="CheckUpdate_Click" />
                    <Button x:Name="ExportButton" MinWidth="86" Height="42" Margin="8,0,0,0" Click="ExportSettings_Click" />
                    <Button x:Name="ImportButton" MinWidth="86" Height="42" Margin="8,0,0,0" Click="ImportSettings_Click" />
                    <Button x:Name="RestoreBackupButton" MinWidth="112" Height="42" Margin="8,0,0,0" Click="RestoreBackup_Click" />
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#2563EB" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CancelButton" MinWidth="90" Height="42" Margin="8,0,0,0" Click="Cancel_Click" />
                        <Button x:Name="ApplyButton" MinWidth="90" Height="42" Margin="8,0,0,0" Click="Apply_Click" />
                        <Button x:Name="OkButton" MinWidth="90" Height="42" Margin="8,0,0,0" Click="Ok_Click" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
