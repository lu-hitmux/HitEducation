<Window x:Class="HitEducation.App.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360"
        Height="160"
        Icon="icons/hiteducation-app-mono.ico"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    <Border x:Name="SplashRoot" CornerRadius="8" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" Padding="22">
        <StackPanel VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Image Source="icons/hiteducation-app-mono.png" Width="28" Height="28" Margin="0,0,9,0" />
                <TextBlock x:Name="TitleText" Text="课堂作业正在启动" FontSize="22" FontWeight="SemiBold" Foreground="#172033" />
            </StackPanel>
            <ProgressBar Height="10" Margin="0,22,0,0" IsIndeterminate="True" />
            <TextBlock x:Name="DetailText" Text="加载数据和窗口状态" Margin="0,12,0,0" Foreground="#667085" />
        </StackPanel>
    </Border>
</Window>
